CREATE EXTENSION pg_ducklake_sync CASCADE;
NOTICE:  installing required extension "pg_duckdb"
-- Check metadata tables exist
SELECT count(*) FROM ducklake_sync.sync_groups;
 count 
-------
     1
(1 row)

SELECT count(*) FROM ducklake_sync.table_mappings;
 count 
-------
     0
(1 row)

-- Test table management (doesn't require wal_level=logical)
CREATE TABLE t1 (id int primary key, val text);
-- Add table to default group
SELECT ducklake_sync.add_table('public.t1', 'ducklake.t1', 'default', false);
 add_table 
-----------
 
(1 row)

-- Check table mapping was added
SELECT source_schema, source_table, target_schema, target_table FROM ducklake_sync.table_mappings;
 source_schema | source_table | target_schema | target_table 
---------------+--------------+---------------+--------------
 public        | t1           | ducklake      | t1
(1 row)

-- Move table
SELECT ducklake_sync.move_table('public.t1', 'default');
 move_table 
------------
 
(1 row)

-- Check it's still there
SELECT source_schema, source_table FROM ducklake_sync.table_mappings;
 source_schema | source_table 
---------------+--------------
 public        | t1
(1 row)

-- Remove table
SELECT ducklake_sync.remove_table('public.t1');
 remove_table 
--------------
 
(1 row)

-- Check it's gone
SELECT count(*) FROM ducklake_sync.table_mappings;
 count 
-------
     0
(1 row)

-- Cleanup
DROP TABLE t1;
DROP EXTENSION pg_ducklake_sync;
